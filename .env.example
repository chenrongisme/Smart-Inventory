# .env.example
# Required
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server
PORT=3000
NODE_ENV=production

# AI Configuration (optional - AI features won't work without this)
AI_API_KEY=
MODEL_TYPE=gemini  # gemini, doubao, qwen, ernie, gemma, minimax
AI_MODEL_NAME=gemini-1.5-flash
AI_ENDPOINT=  # Optional: for custom/gemma endpoints

# Database (optional - defaults to ./data/inventory.db)
# DATABASE_URL=./data/inventory.db
